\@writefile{lof}{\contentsline {figure}{\numberline {3.7}{\ignorespaces 在多尺度设置下，LiteFM-RSDet与LSKNet-S在DOTAv1.0数据集上的对比评估。在类别层面上，所提出的模型在检测具有复杂结构或大尺度变化的目标时展现出明显的优势，mAP提升通常超过1\%。特别是对于SV和HC类别，观察到了2–3\%的性能提升，这突显了LiteFM-RSDet在小目标建模、旋转不变性和背景抑制方面的有效性。}}{38}{figure.caption.19}\protected@file@percent }
\newlabel{fig:DOTAV1}{{3.7}{38}{在多尺度设置下，LiteFM-RSDet与LSKNet-S在DOTAv1.0数据集上的对比评估。在类别层面上，所提出的模型在检测具有复杂结构或大尺度变化的目标时展现出明显的优势，mAP提升通常超过1\%。特别是对于SV和HC类别，观察到了2–3\%的性能提升，这突显了LiteFM-RSDet在小目标建模、旋转不变性和背景抑制方面的有效性。}{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.8}{\ignorespaces 在 DIOR-R 数据集上与最先进（SOTA）轻量级目标检测方法的对比。我们的方法在保持显著降低的计算开销的同时，取得了卓越的准确率。}}{39}{figure.caption.20}\protected@file@percent }
\newlabel{fig:DIOR-R}{{3.8}{39}{在 DIOR-R 数据集上与最先进（SOTA）轻量级目标检测方法的对比。我们的方法在保持显著降低的计算开销的同时，取得了卓越的准确率。}{figure.caption.20}{}}
